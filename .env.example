# ParserX environment variables
# Copy to .env and fill in your values.

# ── LLM / VLM services ────────────────────────────────────────────────
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
LLM_MODEL=gpt-5.4-mini
VLM_MODEL=gpt-5.4-mini

# ── PaddleOCR service ─────────────────────────────────────────────────
PADDLE_OCR_ENDPOINT=
PADDLE_OCR_TOKEN=
